DATABASE_URL=postgresql://tooldb:tooldb@localhost:5432/tooldb

# Render Postgres sync (local admin "Sync Render DB" button)
# External URL must include ?sslmode=require
RENDER_POSTGRES_EXTERNAL_URL=
# Internal URL (used by Render services; not needed locally)
# RENDER_POSTGRES_URL=
RENDER_API_KEY=

# LLM-backed extraction
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
LLM_WEB_RESEARCH_ENABLED=false
# Optional overrides for a browsing-capable enrichment model/provider.
# Falls back to OPENAI_* / LLM_* if unset.
OPENAI_WEB_RESEARCH_API_KEY=
OPENAI_WEB_RESEARCH_BASE_URL=
OPENAI_WEB_RESEARCH_MODEL=
LLM_MAX_CONCURRENCY=64

# Optional upstream provider settings for hosted /api/query prompt parsing.
# This is the server-side LLM provider key used by your deployment. End users should never send it.
# Falls back to OPENAI_* / LLM_* if these are unset.
TOOL_DB_QUERY_UPSTREAM_API_KEY=
TOOL_DB_QUERY_UPSTREAM_BASE_URL=https://api.openai.com/v1
TOOL_DB_QUERY_UPSTREAM_MODEL=gpt-5-nano

# Legacy aliases kept for compatibility:
# TOOL_DB_QUERY_LLM_API_KEY=
# TOOL_DB_QUERY_LLM_BASE_URL=https://api.openai.com/v1
# TOOL_DB_QUERY_LLM_MODEL=gpt-5-nano

# Optional protection for the public /api/query endpoint.
# This is a site-issued client key for callers to your hosted endpoint, not an OpenAI key.
# If TOOL_DB_QUERY_CLIENT_API_KEY is set, callers must send x-api-key or Authorization: Bearer.
# If TOOL_DB_QUERY_RATE_LIMIT_MAX_REQUESTS is set above 0, requests are rate-limited per client IP.
TOOL_DB_QUERY_CLIENT_API_KEY=

# Legacy alias kept for compatibility:
# TOOL_DB_QUERY_API_KEY=

TOOL_DB_QUERY_RATE_LIMIT_MAX_REQUESTS=30
TOOL_DB_QUERY_RATE_LIMIT_WINDOW_MS=60000

# Source APIs
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=
